.venv/
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/

*.pyc
*.pyo
*.pyd

data/raw/*
data/processed/*
outputs/*
reports/*.html
reports/*.pdf

!data/raw/.gitkeep
!data/processed/.gitkeep
!outputs/.gitkeep
!reports/.gitkeep

.env
.DS_Store
.ipynb_checkpoints/

*.egg-info/

# Commit tiny reproducible sample data, but keep raw/processed local.
!data/sample/
!data/sample/*.csv
data/external/*
!data/external/.gitkeep
